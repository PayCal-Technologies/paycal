<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.paycal.redis-sync</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/private/var/www/paycal-mac/dev/scripts/redis-sync.sh</string>
        <string>once</string>
    </array>
    
    <key>StartInterval</key>
    <integer>300</integer>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/private/var/www/paycal-mac/dev/logs/redis-sync-stdout.log</string>
    
    <key>StandardErrorPath</key>
    <string>/private/var/www/paycal-mac/dev/logs/redis-sync-stderr.log</string>
    
    <key>WorkingDirectory</key>
    <string>/private/var/www/paycal-mac/dev</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>
    
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
