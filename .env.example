# Runtime environment profile (for example: local/mac/dev/staging/prod).
APP_ENV=mac
# URL scheme used for generated absolute links.
APP_SCHEME=http
# Application host/domain used in links and routing assumptions.
APP_DOMAIN=mac.paycal.local
# Absolute filesystem path to the project root used by bootstrap logic.
APP_HOME=/var/www/paycal-private/
# API version namespace exposed by server endpoints.
API_VERSION=v1

# Redis host used for cache/session and other Redis-backed operations.
REDIS_SERVER=127.0.0.1
# Primary Redis TCP port.
REDIS_PORT=6379
# Redis port dedicated to read operations (can match REDIS_PORT locally).
REDIS_READ_PORT=6379
# Redis port dedicated to write operations (can match REDIS_PORT locally).
REDIS_WRITE_PORT=6379
# Redis logical database index.
REDIS_DB=0
# Enable ACL auth for Redis connection; false for local unsecured setups.
REDIS_AUTH_ENABLED=false
# Redis ACL username when auth is enabled.
REDIS_USER=paycal
# Redis ACL password when auth is enabled; leave blank for local no-auth.
REDIS_PASSWORD=
# Session TTL in seconds for newly created sessions.
REDIS_NEW_SESSION_TTL=3600

# SMTP hostname used for outbound email delivery.
PC_EMAIL_SMTP_SERVER=smtp.titan.email
# SMTP port used by outbound email transport.
PC_EMAIL_SMTP_PORT=587
# Contact/from address used in app email flows.
PC_EMAIL_CONTACT=info@paycal.app
# Optional verbose SMTP debug mode flag/value.
PC_EMAIL_DEBUG=
# Reply-To address for outbound emails.
PC_EMAIL_REPLYTO=info@paycal.app
# SMTP account password/secret.
PC_EMAIL_PASSWORD=
# Optional registration gate code for controlled onboarding.
PC_REGISTRATION_CODE=
# Optional invite code gate for invite-only workflows.
PC_INVITE_CODE=

# API key for OpenAI-backed features; leave blank when not used.
PC_OPENAI_API_KEY=

# Salt used in UUID/token derivations where applicable.
UUID_SALT=
# App-level symmetric secret key for sodium-based crypto operations.
SODIUM_CRYPTO_SECRET_KEY=

# Private key used for payroll signing operations.
PAYROLL_SIGNING_PRIVATE_KEY=
# Public key paired with payroll signing private key.
PAYROLL_SIGNING_PUBLIC_KEY=
# Development-only bypass for strict CSP inline script restrictions.
DEV_ALLOW_INLINE_SCRIPTS=false

# Master development security toggle.
# When true, disables CSP headers and encryption endpoints for local debugging.
# Never enable in production.
DEV_SECURITY_DISABLED=false

# Client-side encryption feature toggle.
# When false, encryption endpoints return 503 by design.
# Effective value is forced off when DEV_SECURITY_DISABLED=true.
ENCRYPTION_ENABLED=false